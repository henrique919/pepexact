# Copy to apps/web/.env.local for local overrides (never commit secrets).

# Canonical site origin (no trailing slash). Used for sitemap, JSON-LD, OG.
NEXT_PUBLIC_SITE_URL=https://pepexact.com

# Optional waitlist CTA after calculator results (http(s) or mailto).
# NEXT_PUBLIC_WAITLIST_URL=https://forms.gle/your-form-id

# GA4 measurement ID. Defaults to G-6B35Q3CXCT in code when unset.
# Set to empty string to disable analytics scripts entirely.
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-6B35Q3CXCT
